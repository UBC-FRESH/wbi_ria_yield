  <!--
      Middle matrix builder constants
  -->

  <!--
      Stratification fields
  -->

 <repeat name="theme" list="sort(filter(tablelist('fragments'),'THEME(\d+)'))">
  <define field="lower(getEnv('repeat.theme'))" column="Upper(String(column(getEnv('repeat.theme'))))" />
 </repeat>
  <define field="ecode" column="'_EXISTING'" />
  <define field="MartStrata" column="MartStrata" />
  <define field="TPR" column="if(TPR='U','F',TPR)" />
  <define field="treatment" />

  <!--
      Matrix builder constants
  -->

  <define field="eligible" constant="'ST,P1'" />
  <define field="seralList" constant="unique(filter(curveNames(),'.*Seral.(.*)','{1}'))" />

  <!--
       Exec commands
  -->


  <!--
      Required input fields
  -->

  <input block="Int(BLOCK)" area="AREA/10000" age="F_AGE" exclude="BLOCK = 0"  />

  <!--
      Override the default output file names
  -->
  <output accounts="accounts.csv" />


  <!--

   Aspatial netdown section

  -->


<!-- Include location for entity afterRetention  -->


  <!--

      Catch unmanaged tracks

  -->

  <select statement="theme2 = 'N' or theme3 = 'D'">
    <track>
    </track>
  </select>

<!-- Include location for entity afterUnmanaged  -->


  <!--

      Stratum descriptions

  -->


  <!--

      Values from stratum sheet named 'Responses'

  -->

  <select>
    <succession breakup="Number(tablemap('YC_lookup','theme2',theme2,'Breakup'))" renew="Number(tablemap('YC_lookup','theme2',theme2,'Renew'))" >
    </succession>
  </select>

  <select statement="theme1 in eligible and theme2 in tableList('YC_lookup', 'theme2', q($REGMIN ne ''$)) and theme3 in 'N' and theme4 in 'REGMIN'">
    <track>
      <treatment label="CC" minage="Number(tableMap('YC_lookup', 'theme2', theme2, 'REGMIN','a'))">
        <produce>
          <assign field="treatment" value="'CC'"/>
        </produce>
        <transition>
          <assign field="ecode" value="'_FUTUR_'"/>
        </transition>
      </treatment>
    </track>
  </select>

  <select statement="theme1 in eligible and theme2 in tableList('YC_lookup', 'theme2', q($OLDMIN ne ''$)) and theme3 in 'N' and theme4 in 'OLDMIN'">
    <track>
      <treatment label="CC" minage="Number(tableMap('YC_lookup', 'theme2', theme2, 'OLDMIN','a'))">
        <produce>
          <assign field="treatment" value="'CC'"/>
        </produce>
        <transition>
          <assign field="ecode" value="'_FUTUR_'"/>
        </transition>
      </treatment>
    </track>
  </select>

<!-- Include location for entity afterStratum  -->


  <!--

      Attributes from 'General Attributes'

  -->

  <select statement="">
    <features>
      <attribute label="%f.young" cycle="false">
        <curve idref="Visual"/>
      </attribute>
      <attribute label="total.Area">
        <curve idref="one"/>
      </attribute>
    </features>
  </select>

  <select statement="theme5 ne 'NS'">
    <features>
     <repeat name="seral" list="seralList">
      <attribute label=" '%f.Seral.'+getEnv('repeat.seral')">
        <expression statement="curveId(theme5+'.Seral.'+getEnv('repeat.seral'))" by="1" ignoreMissingAttributes="false"/>
      </attribute>
     </repeat>
    </features>
  </select>

  <select statement="">
    <features>
      <attribute label=" '%f.Area.%m.'+theme5">
        <curve idref="one"/>
      </attribute>
    </features>
  </select>

 <repeat name="species" list="unique(filter(curveNames(),'Y\d.(.*)','{1}'))">
  <select statement="">
    <features>
      <attribute label=" '%f.Yield.%m.'+getEnv('repeat.species')">
        <expression statement="curveId(theme2+'.'+getEnv('repeat.species'))" by="1" ignoreMissingAttributes="false"/>
      </attribute>
      <attribute label=" '%f.total.Yield'">
        <expression statement="curveId(theme2+'.'+getEnv('repeat.species'))" by="1" ignoreMissingAttributes="false"/>
      </attribute>
      <attribute label=" '%f.Opgs.%m.'+getEnv('repeat.species')">
        <expression statement="Operable(curveId(theme2+'.'+getEnv('repeat.species')))" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </features>
  </select>
 </repeat>

  <select statement="theme5 in 'PL'">
    <features>
      <attribute label="feature.ECA.Recovery">
        <expression statement="curveId('ECA_C-P-'+TPR)/100" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </features>
  </select>

  <select statement="theme5 in 'SB'">
    <features>
      <attribute label="feature.ECA.Recovery">
        <expression statement="curveId('ECA_C-Sb-'+TPR)/100" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </features>
  </select>

  <select statement="theme5 in 'SW,DF,SEFA,SWWET'">
    <features>
      <attribute label="feature.ECA.Recovery">
        <expression statement="curveId('ECA_C-Sw-'+TPR)/100" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </features>
  </select>

  <select statement="theme5 in 'DEC'">
    <features>
      <attribute label="feature.ECA.Recovery">
        <expression statement="curveId('ECA_D-'+TPR)/100" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </features>
  </select>

  <select statement="theme5 in 'CDDFMIX,CDCONMIX,DCDFMIX,DCCONMIX'">
    <features>
      <attribute label="feature.ECA.Recovery">
        <expression statement="curveId('ECA_MX-'+TPR)/100" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </features>
  </select>

  <select statement="MartStrata ne 0">
    <features>
      <attribute label="feature.NTA.Marten">
        <expression statement="curveId('Marten.'+MartStrata)" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </features>
  </select>

  <select statement="">
    <products>
      <attribute label="product.harvested">
        <curve idref="one"/>
      </attribute>
    </products>
  </select>

  <select statement="theme5 ne 'NS'">
    <products>
     <repeat name="seral" list="seralList">
      <attribute label=" '%f.Seral.'+getEnv('repeat.seral')">
        <expression statement="curveId(theme5+'.Seral.'+getEnv('repeat.seral'))" by="1" ignoreMissingAttributes="false"/>
      </attribute>
     </repeat>
    </products>
  </select>

  <select statement="">
    <products>
      <attribute label=" '%f.Area.%m.'+theme5">
        <curve idref="one"/>
      </attribute>
    </products>
  </select>

 <repeat name="species" list="unique(filter(curveNames(),'Y\d.(.*)','{1}'))">
  <select statement="">
    <products>
      <attribute label=" '%f.Yield.%m.'+getEnv('repeat.species')">
        <expression statement="curveId(theme2+'.'+getEnv('repeat.species'))" by="1" ignoreMissingAttributes="false"/>
      </attribute>
      <attribute label=" '%f.total.Yield'">
        <expression statement="curveId(theme2+'.'+getEnv('repeat.species'))" by="1" ignoreMissingAttributes="false"/>
      </attribute>
    </products>
  </select>
 </repeat>

  <select statement="">
    <products>
     <repeat name="range" table="VphRange">
      <attribute label=" '%f.vph.'+getEnv('repeat.range.Label')">
        <expression statement="if(lookupCurve(attribute('%f.total.Yield'),offset()) ge Number(getEnv('repeat.range.Min')) and lookupCurve(attribute('%f.total.Yield'),offset()) lt number(getEnv('repeat.range.Max')),1,0)" by="1" ignoreMissingAttributes="false"/>
      </attribute>
     </repeat>
    </products>
  </select>

