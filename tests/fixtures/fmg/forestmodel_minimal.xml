<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE ForestModel SYSTEM "ForestModel.dtd">
<ForestModel description="FEMIC Patchworks export" horizon="300" year="2026" match="multi">
  <input block="BLOCK" area="AREA_HA" age="F_AGE" exclude="BLOCK=0" />
  <output messages="messages.csv" blocks="blocks.csv" features="features.csv" products="products.csv" treatments="treatments.csv" curves="curves.csv" tracknames="tracknames.csv" />
  <define field="AU" column="AU" />
  <define field="IFM" column="IFM" />
  <define field="treatment" />
  <curve id="unity">
    <point x="0" y="1.0" />
  </curve>
  <curve id="managed_total_985521000">
    <point x="1" y="12.000000" />
    <point x="10" y="70.000000" />
  </curve>
  <curve id="unmanaged_total_985501000">
    <point x="1" y="10.000000" />
    <point x="10" y="55.000000" />
  </curve>
  <select statement="AU eq '985501000' and IFM eq 'unmanaged'">
    <features>
      <attribute label="feature.Area.unmanaged">
        <curve idref="unity" />
      </attribute>
      <attribute label="feature.Yield.unmanaged.Total">
        <curve idref="unmanaged_total_985501000" />
      </attribute>
    </features>
    <track />
  </select>
  <select statement="AU eq '985501000' and IFM eq 'managed'">
    <features>
      <attribute label="feature.Area.managed">
        <curve idref="unity" />
      </attribute>
      <attribute label="feature.Yield.managed.Total">
        <curve idref="managed_total_985521000" />
      </attribute>
    </features>
    <track>
      <treatment label="CC" minage="0" maxage="1000">
        <produce>
          <assign field="treatment" value="'CC'" />
        </produce>
        <transition>
          <assign field="IFM" value="'managed'" />
        </transition>
      </treatment>
    </track>
  </select>
  <select statement="AU eq '985501000' and IFM eq 'managed' and treatment eq 'CC'">
    <products>
      <attribute label="product.Treated.managed.CC">
        <curve idref="unity" />
      </attribute>
      <attribute label="product.Yield.managed.Total">
        <curve idref="managed_total_985521000" />
      </attribute>
    </products>
  </select>
</ForestModel>
