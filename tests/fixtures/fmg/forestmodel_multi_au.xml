      <attribute label="feature.SpeciesProp.managed.FD">
        <curve idref="C21001002" />
      </attribute>
      <attribute label="feature.SpeciesProp.managed.PL">
        <curve idref="C21001001" />
      </attribute>
    </features>
    <track>
      <treatment label="CC" minage="0" maxage="1000">
        <produce>
          <assign field="treatment" value="'CC'" />
        </produce>
      </treatment>
    </track>
  </select>
  <select statement="AU eq '1001' and IFM eq 'managed' and treatment eq 'CC'">
    <products>
      <attribute label="product.Treated.managed.CC">
        <curve idref="unity" />
      </attribute>
