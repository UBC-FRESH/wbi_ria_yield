  </curve>
  <curve id="C21002002">
    <point x="1.000000" y="0.400000" />
  </curve>
  <select statement="AU eq '1001' and IFM eq 'unmanaged'">
    <features>
      <attribute label="feature.Area.unmanaged">
        <curve idref="unity" />
      </attribute>
      <attribute label="feature.Yield.unmanaged.Total">
        <curve idref="C1001" />
      </attribute>
      <attribute label="feature.SpeciesProp.unmanaged.FD">
        <curve idref="C1001002" />
      </attribute>
      <attribute label="feature.SpeciesProp.unmanaged.PL">
        <curve idref="C1001001" />
      </attribute>
    </features>
    <track />
  </select>
  <select statement="AU eq '1001' and IFM eq 'managed'">
